# Frontend (Next.js) — the FastAPI base URL the browser calls.
# Local dev default (in lib/api-client.ts) is http://127.0.0.1:8000 if unset.
NEXT_PUBLIC_API_BASE_URL=https://sales-ops-6e84.onrender.com

# Backend (FastAPI) — comma-separated allowed CORS origins, trimmed, empty
# entries dropped. Local dev default (in backend/main.py) is
# http://localhost:3000 if unset.
CORS_ALLOWED_ORIGINS=https://sales-ops-gamma.vercel.app/

# Backend (FastAPI) — Postgres connection string for the Workflow Results
# Store (docs/adr/0007). Render's env holds the `main` branch string as a
# secret; locally this should point at your Neon `dev` branch. If unset,
# persistence is disabled and the app still runs normally (see backend/db.py).
DATABASE_URL=

# Backend (pytest) — a separate Neon `test` branch string, used only by
# @pytest.mark.db repository/migration tests. Deliberately not DATABASE_URL,
# so a misconfigured environment can never point a cleanup/rollback-driven
# test at `dev` or `main`. Those tests skip (not fail) when this is unset.
TEST_DATABASE_URL=